---
const steps = [
  ["Idea", "💡"],
  ["Diseño", "✏️"],
  ["MVP", "⚙️"],
  ["Evolución", "🚀"],
  ["Despliegue", "🌐"],
  ["Defensa", "🎯"],
];
---

<div class="diagram-flow">
  {steps.map(([label, icon], i) => (
    <>
      <div class="diagram-step" style="background: var(--sl-color-accent)">
        <span style="font-size:1.5rem">{icon}</span>
        <span>{label}</span>
      </div>
      {i < steps.length - 1 && <span class="diagram-arrow">→</span>}
    </>
  ))}
</div>

<div style="display:flex; justify-content:center; gap:2rem; margin-top:1rem; font-size:0.875rem;">
  <span style="display:flex; align-items:center; gap:0.5rem;">
    <span style="display:inline-block; width:12px; height:12px; border-radius:50%; background:#2563eb;"></span>
    PI1 (1º DAW)
  </span>
  <span style="display:flex; align-items:center; gap:0.5rem;">
    <span style="display:inline-block; width:12px; height:12px; border-radius:50%; background:#7c3aed;"></span>
    PI2 (2º DAW)
  </span>
</div>
